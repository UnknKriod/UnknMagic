<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/fab"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_marginTop="24dp"
            app:cornerRadius="80dp"
            app:icon="@drawable/ic_play_24dp"
            app:iconSize="56dp"
            app:iconGravity="textStart"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            app:iconPadding="0dp"
            app:backgroundTint="@color/color_fab_inactive"
            app:elevation="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tv_test_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/connection_not_connected"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/md_theme_onSurface"
            android:gravity="center"
            android:padding="8dp"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/fab"
            tools:text="Not Connected" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_stop_test"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/action_stop_test"
            android:visibility="gone"
            android:textColor="@color/color_fab_inactive"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_test_state" />

        <com.google.android.material.tabs.TabLayout
            android:id="@+id/tab_mode"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_marginTop="16dp"
            android:background="@android:color/transparent"
            android:visibility="gone"
            app:tabIndicatorHeight="0dp"
            app:tabRippleColor="@android:color/transparent"
            app:tabBackground="@drawable/tab_selector"
            app:tabTextColor="@color/color_fab_inactive"
            app:tabSelectedTextColor="@android:color/white"
            app:tabMode="fixed"
            app:tabPaddingStart="16dp"
            app:tabPaddingEnd="16dp"
            app:tabMinWidth="100dp"
            app:tabGravity="center"
            app:layout_constraintTop_toBottomOf="@id/btn_stop_test"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/plugin_mode_standard" />

            <com.google.android.material.tabs.TabItem
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/plugin_mode_premium" />
        </com.google.android.material.tabs.TabLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:paddingHorizontal="24dp"
            android:paddingBottom="24dp"
            android:orientation="vertical"
            app:layout_constraintTop_toBottomOf="@id/tab_mode"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/tv_recent_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="@string/recent_servers"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:textColor="@color/color_fab_inactive" />

            <LinearLayout
                android:id="@+id/card_recent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_no_premium_subs"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp"
                    android:gravity="center"
                    android:text="@string/no_premium_subscriptions"
                    android:textColor="@color/color_fab_inactive"
                    android:visibility="gone" />

                <LinearLayout
                    android:id="@+id/layout_recent_servers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_top_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="TOP 10 BY PING"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:textColor="@color/color_fab_inactive" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_top_servers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:nestedScrollingEnabled="false"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_server_top" />

            <LinearLayout
                android:id="@+id/layout_empty_top"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:visibility="gone"
                android:layout_marginTop="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="No speed test data"
                    android:textColor="@color/color_fab_inactive"
                    android:layout_marginBottom="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_ping_all_empty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Test All Servers"
                    app:icon="@drawable/ic_cloud_download_24dp" />
            </LinearLayout>

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
